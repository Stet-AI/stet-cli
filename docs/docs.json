{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Stet",
  "description": "Change control for AI coding agents.",
  "theme": "willow",
  "colors": {
    "primary": "#df3328",
    "light": "#e8352a",
    "dark": "#df3328"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "logo": {
    "light": "/assets/stet-mark.svg",
    "dark": "/assets/stet-mark.svg"
  },
  "favicon": "/assets/stet-mark.svg",
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp",
      "cursor",
      "vscode"
    ],
    "display": "header"
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "quickstart",
          "first-eval"
        ]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/how-stet-works",
          "concepts/grading",
          "concepts/trial-result",
          "concepts/vocabulary",
          "concepts/release-lifecycle"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "workflows",
          "guides/instruction-file-ab",
          "guides/model-comparison",
          "guides/skill-evaluation",
          "guides/iterative-improvement"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "prompts",
          "troubleshooting"
        ]
      }
    ]
  }
}
